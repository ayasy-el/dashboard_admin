      "definition": "SELECT date_trunc('month'::text, transaction_at)::date AS month_year, merchant_key, category, branch, cluster, uniq_merchant, count(*)::integer AS tx_count, count(*) FILTER (WHERE status = 'success'::transaction_status)::integer AS success_tx_count, count(*) FILTER (WHERE status = 'failed'::transaction_status)::integer AS failed_tx_count, count(DISTINCT msisdn)::integer AS unique_redeemer, count(DISTINCT msisdn) FILTER (WHERE status = 'success'::transaction_status)::integer AS unique_redeemer_success, COALESCE(sum(total_point) FILTER (WHERE status = 'success'::transaction_status), 0::numeric)::bigint AS total_point_success FROM vw_overview_transaction vt GROUP BY (date_trunc('month'::text, transaction_at)::date), merchant_key, category, branch, cluster, uniq_merchant",
